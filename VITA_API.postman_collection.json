{
  "info": {
    "name": "VITA API",
    "description": "Complete API collection for the VITA AI Life Manager backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api" },
    { "key": "token",    "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json(); if(r.token) pm.collectionVariables.set('token', r.token);"] } }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@vita.app\",\n  \"password\": \"vita123\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json(); if(r.token) pm.collectionVariables.set('token', r.token);"] } }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@vita.app\",\n  \"password\": \"vita123\"\n}" }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tasks",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/tasks",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Write project report\",\n  \"energy\": \"high\",\n  \"category\": \"Work\",\n  \"notes\": \"Needs deep focus\"\n}" }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/tasks/TASK_ID_HERE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated task name\",\n  \"energy\": \"medium\"\n}" }
          }
        },
        {
          "name": "Toggle Task Done",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/tasks/TASK_ID_HERE/toggle",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/tasks/TASK_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Energy",
      "item": [
        {
          "name": "Log Energy Level",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/energy",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"level\": \"medium\"\n}" }
          }
        },
        {
          "name": "Energy History",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/energy/history",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Wellbeing",
      "item": [
        {
          "name": "Get Today Wellbeing",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/wellbeing",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Add Water (+1 glass)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/wellbeing",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"add_water\": 1\n}" }
          }
        },
        {
          "name": "Log Meal",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/wellbeing",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"log_meal\": true\n}" }
          }
        },
        {
          "name": "Log Movement (+5 min)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/wellbeing",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"add_move\": 5\n}" }
          }
        },
        {
          "name": "Log Rest (+10 min)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/wellbeing",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"add_rest\": 10\n}" }
          }
        },
        {
          "name": "Get Wellness Tip",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/wellbeing/tip",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/chat",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"message\": \"What should I do first today?\"\n}" }
          }
        },
        {
          "name": "Get Chat History",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/chat/history",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Clear Chat History",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/chat",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
